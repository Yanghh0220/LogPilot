# ============================================================
#  LogPilot 环境变量配置模板
#  使用方法：复制此文件为 .env，然后填入你的真实配置
#  命令：cp .env.example .env
# ============================================================

# ------------------------------------------------------------
#  AI 服务商选择（必填）
#  支持所有兼容 OpenAI 接口的服务商
#  可选值：deepseek / openai / moonshot / zhipu / custom
# ------------------------------------------------------------
AI_PROVIDER=deepseek

# ------------------------------------------------------------
#  API Key（必填）
#  根据你选择的 AI_PROVIDER，填入对应的 API Key
# ------------------------------------------------------------

# DeepSeek（推荐，性价比高，中文能力强）
# 注册地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_api_key_here

# OpenAI（GPT-4o / GPT-4）
# 注册地址：https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Moonshot（月之暗面，国产模型）
# 注册地址：https://platform.moonshot.cn/
# MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 智谱 AI（GLM-4 系列）
# 注册地址：https://open.bigmodel.cn/
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
#  以下为可选配置，有默认值，一般不需要修改
# ------------------------------------------------------------

# API 请求地址（默认根据 AI_PROVIDER 自动选择）
# 如果你用的是自建代理或其他兼容 OpenAI 的服务商，改这里
# 格式：https://your-api-host.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称（默认根据 AI_PROVIDER 自动选择）
# DeepSeek 可选：deepseek-chat（通用）、deepseek-coder（代码专用）
# OpenAI 可选：gpt-4o、gpt-4、gpt-3.5-turbo
# Moonshot 可选：moonshot-v1-8k、moonshot-v1-32k、moonshot-v1-128k
# DEEPSEEK_MODEL=deepseek-chat

# 温度参数（默认：0）
# 控制 AI 回答的随机性：
#   0   = 最稳定、可重复（推荐，分析日志用这个）
#   0.3 = 略有变化，适合日常对话
#   1.0 = 最有创意、随机性最高
# TEMPERATURE=0

# 最大 Token 数（默认：4096）
# 控制 AI 单次回答的最大长度，一般不需要改
# MAX_TOKENS=4096
